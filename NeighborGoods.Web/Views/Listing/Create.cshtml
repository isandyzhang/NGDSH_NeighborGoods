@model NeighborGoods.Web.Models.ViewModels.ListingCreateViewModel

@{
    ViewData["Title"] = "刊登商品";
}

<h2 class="mt-4 mb-3">刊登商品</h2>

<!-- 刊登送出時的載入遮罩 -->
<div id="submitLoadingOverlay" class="submit-loading-overlay d-none" aria-hidden="true">
    <div class="submit-loading-content">
        <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">載入中</span>
        </div>
        <p class="mt-3 mb-0 text-white fw-bold">刊登商品中，請稍候...</p>
    </div>
}</div>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="createForm">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold">標題</label>
                <input asp-for="Title" class="form-control form-control-lg" maxlength="200" />
                <div class="form-text">最多 200 個字元</div>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-bold">商品類別</label>
                <select asp-for="Category" 
                        asp-items="Html.GetEnumSelectList<NeighborGoods.Web.Models.Enums.ListingCategory>()" 
                        class="form-select form-select-lg" 
                        style="font-size: 16px;">
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Condition" class="form-label fw-bold">新舊程度</label>
                <select asp-for="Condition" 
                        asp-items="Html.GetEnumSelectList<NeighborGoods.Web.Models.Enums.ListingCondition>()" 
                        class="form-select form-select-lg" 
                        style="font-size: 16px;">
                </select>
                <span asp-validation-for="Condition" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Residence" class="form-label fw-bold">商品位於的社宅</label>
                @{
                    var residenceItems = Html
                        .GetEnumSelectList<NeighborGoods.Web.Models.Enums.ListingResidence>()
                        .Where(item => item.Value != ((int)NeighborGoods.Web.Models.Enums.ListingResidence.Unknown).ToString());
                }
                <select asp-for="Residence"
                        asp-items="residenceItems"
                        class="form-select form-select-lg"
                        style="font-size: 16px;">
                </select>
                <span asp-validation-for="Residence" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">描述</label>
                <textarea asp-for="Description" class="form-control" rows="5" maxlength="500"></textarea>
                <div class="form-text">最多 500 個字元</div>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-bold">價格</label>
                <input asp-for="Price" 
                       id="Price"
                       class="form-control form-control-lg" 
                       type="number" 
                       inputmode="numeric"
                       step="1" 
                       min="0" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check form-check-lg">
                <input asp-for="IsFree" id="IsFree" class="form-check-input" type="checkbox" style="width: 1.5rem; height: 1.5rem;" />
                <label asp-for="IsFree" class="form-check-label fs-5">免費索取</label>
            </div>

            <div class="mb-3 form-check form-check-lg">
                <input asp-for="IsCharity" id="IsCharity" class="form-check-input charity-checkbox" type="checkbox" style="width: 1.5rem; height: 1.5rem;" />
                <label asp-for="IsCharity" class="form-check-label fs-5">愛心商品</label>
                <div class="form-text mt-1">
                    <small class="text-muted">愛心商品可讓公益團體免費索取，一起做愛心！</small>
                </div>
            </div>

            <div class="mb-3 form-check form-check-lg">
                <input asp-for="IsTradeable" id="IsTradeable" class="form-check-input" type="checkbox" style="width: 1.5rem; height: 1.5rem;" />
                <label asp-for="IsTradeable" class="form-check-label fs-5">可否以物易物</label>
                <div class="form-text mt-1">
                    <small class="text-muted">勾選後代表您願意接受以物易物或交換的方式，價格仍照一般方式顯示。</small>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="PickupLocation" class="form-label fw-bold">面交地點</label>
                <select asp-for="PickupLocation" 
                        asp-items="Html.GetEnumSelectList<NeighborGoods.Web.Models.Enums.ListingPickupLocation>()" 
                        class="form-select form-select-lg" 
                        style="font-size: 16px;">
                </select>
                <span asp-validation-for="PickupLocation" class="text-danger"></span>
            </div>

            <hr />
            <h5 class="mb-3">商品圖片（至少 1 張，最多 5 張）<span class="text-danger">*</span></h5>
            <div class="form-text mb-3">支援格式：JPG, JPEG, PNG, GIF, WEBP, HEIC, HEIF。每張圖片大小限制：5MB。您可以點擊拍照或從相簿選擇圖片上傳。</div>

            <!-- 圖片上傳區域 - 手機優化 -->
            <div class="row g-3 mb-4">
                @for (int i = 1; i <= 5; i++)
                {
                    <div class="col-6 col-md-4">
                        <div class="image-upload-card position-relative">
                            <label for="@($"Image{i}")" class="d-block mb-0" style="cursor: pointer;">
                                <div class="card border-2 border-dashed h-100 d-flex flex-column align-items-center justify-content-center p-3" 
                                     style="min-height: 150px; background-color: #f8f9fa; border-color: #dee2e6 !important;">
                                    <input name="@($"Image{i}")" 
                                           id="@($"Image{i}")"
                                           type="file" 
                                           class="d-none image-input" 
                                           accept="image/jpeg,image/jpg,image/png,image/gif,image/webp,image/heic,image/heif"
                                           data-index="@i" />
                                    <div class="image-preview-container text-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-camera text-muted mb-2" viewBox="0 0 16 16">
                                            <path d="M15 12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1.172a3 3 0 0 0 2.12-.879l.83-.828A1 1 0 0 1 6.827 3h2.344a1 1 0 0 1 .707.293l.828.828A3 3 0 0 0 12.828 5H14a1 1 0 0 1 1 1zM2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4H2z"/>
                                            <path d="M8 11a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5m0 1a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7M3 6.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0"/>
                                        </svg>
                                        <small class="text-muted d-block">點擊拍照或上傳圖片</small>
                                    </div>
                                    <img class="image-preview d-none img-fluid rounded mt-2" style="max-height: 150px; object-fit: cover; width: 100%;" />
                                </div>
                            </label>
                            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 remove-image-btn d-none" 
                                    data-index="@i" 
                                    style="z-index: 10; border-radius: 50%; width: 28px; height: 28px; padding: 0; display: flex; align-items: center; justify-content: center;">
                                <span style="font-size: 14px;">×</span>
                            </button>
                            <span class="text-danger small d-block mt-1" data-valmsg-for="@($"Image{i}")" data-valmsg-replace="true"></span>
                        </div>
                    </div>
                }
            </div>

            <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100 mb-4" style="min-height: 50px; font-size: 1.1rem;">
                <span id="submitBtnText">送出刊登</span>
                <span id="submitBtnSpinner" class="spinner-border spinner-border-sm d-none ms-2" role="status" aria-hidden="true"></span>
            </button>
        </form>
    </div>
    <div class="col-md-4">
        <!-- 置頂功能區塊 -->
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="mb-0">置頂功能</h5>
            </div>
            <div class="card-body">
                <p class="mb-3">
                    <strong>目前可用置頂次數：</strong>
                    <span class="text-warning fw-bold">@Model.AvailableTopPinCredits 次</span>
                </p>
                
                @if (Model.AvailableTopPinCredits > 0)
                {
                    <p class="text-muted mb-3">
                        使用 1 次置頂機會，可讓此商品在首頁置頂 7 天。
                    </p>
                    <div class="form-check mb-3">
                        <input asp-for="UseTopPin" id="UseTopPin" class="form-check-input" type="checkbox" style="width: 1.5rem; height: 1.5rem;" />
                        <label asp-for="UseTopPin" class="form-check-label fs-5">使用 1 次置頂（7 天）</label>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mb-0">
                        您目前沒有可用的置頂次數。<br />
                        <a asp-controller="Account" asp-action="CreateTopSubmission" class="alert-link">投稿合照換置頂次數</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // 圖片預覽功能
        document.querySelectorAll('.image-input').forEach(input => {
            input.addEventListener('change', function(e) {
                const index = this.dataset.index;
                const file = this.files[0];
                const card = this.closest('.image-upload-card');
                const preview = card.querySelector('.image-preview');
                const previewContainer = card.querySelector('.image-preview-container');
                const removeBtn = card.querySelector('.remove-image-btn');

                if (file) {
                    // 驗證檔案大小（前端驗證）
                    const maxSize = 5 * 1024 * 1024; // 5MB
                    if (file.size > maxSize) {
                        alert('圖片大小不能超過 5MB');
                        this.value = '';
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        preview.src = e.target.result;
                        preview.classList.remove('d-none');
                        previewContainer.classList.add('d-none');
                        removeBtn.classList.remove('d-none');
                    };
                    reader.readAsDataURL(file);
                }
            });
        });

        // 移除圖片功能
        document.querySelectorAll('.remove-image-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                const index = this.dataset.index;
                const card = this.closest('.image-upload-card');
                const input = card.querySelector('.image-input');
                const preview = card.querySelector('.image-preview');
                const previewContainer = card.querySelector('.image-preview-container');

                input.value = '';
                preview.classList.add('d-none');
                previewContainer.classList.remove('d-none');
                this.classList.add('d-none');
            });
        });

        // 價格輸入時自動取消免費商品勾選
        const priceInput = document.getElementById('Price');
        const isFreeCheckbox = document.getElementById('IsFree');
        
        if (priceInput && isFreeCheckbox) {
            priceInput.addEventListener('input', function() {
                const price = parseFloat(this.value) || 0;
                // 如果使用者輸入價格（>0）且免費商品已勾選，自動取消勾選
                if (price > 0 && isFreeCheckbox.checked) {
                    isFreeCheckbox.checked = false;
                }
                // 如果價格為 0，自動勾選免費商品
                else if (price === 0 && !isFreeCheckbox.checked) {
                    isFreeCheckbox.checked = true;
                }
            });
        }

        // 免費商品勾選時，如果已有價格，自動清空價格
        if (isFreeCheckbox && priceInput) {
            isFreeCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    const price = parseFloat(priceInput.value) || 0;
                    if (price > 0) {
                        priceInput.value = '0';
                    }
                }
            });
        }

        // 表單送出前檢查：至少需要一張圖片
        const form = document.querySelector('form');
        const submitBtn = document.getElementById('submitBtn');
        const submitBtnText = document.getElementById('submitBtnText');
        const submitBtnSpinner = document.getElementById('submitBtnSpinner');
        const submitLoadingOverlay = document.getElementById('submitLoadingOverlay');
        let isSubmitting = false;
        let loadingDotsInterval = null;
        
        // 顯示載入狀態（按鈕文字「刊登商品中....」點點動畫 + 全畫面遮罩）
        // disableBtn: true 時才停用按鈕（click 時不 disable，避免阻擋 form submit）
        function showLoadingState(disableBtn) {
            if (submitBtn && submitBtnText && submitBtnSpinner) {
                if (disableBtn !== false) submitBtn.disabled = true;
                submitBtnText.textContent = '刊登商品中.';
                submitBtnSpinner.classList.remove('d-none');
                // 點點循環動畫：. → .. → ...
                const dots = ['.', '..', '...'];
                let i = 0;
                if (loadingDotsInterval) clearInterval(loadingDotsInterval);
                loadingDotsInterval = setInterval(function() {
                    i = (i + 1) % dots.length;
                    if (submitBtnText) submitBtnText.textContent = '刊登商品中' + dots[i];
                }, 400);
            }
            if (submitLoadingOverlay) {
                submitLoadingOverlay.classList.remove('d-none');
                submitLoadingOverlay.setAttribute('aria-hidden', 'false');
            }
        }
        
        // 重置按鈕狀態（含隱藏遮罩、清除點點動畫）
        function resetButtonState() {
            if (loadingDotsInterval) {
                clearInterval(loadingDotsInterval);
                loadingDotsInterval = null;
            }
            if (submitBtn && submitBtnText && submitBtnSpinner) {
                submitBtn.disabled = false;
                submitBtnText.textContent = '送出刊登';
                submitBtnSpinner.classList.add('d-none');
            }
            if (submitLoadingOverlay) {
                submitLoadingOverlay.classList.add('d-none');
                submitLoadingOverlay.setAttribute('aria-hidden', 'true');
            }
            isSubmitting = false;
        }
        
        // 頁面載入時隱藏遮罩（例如驗證失敗回到本頁）
        if (submitLoadingOverlay) {
            submitLoadingOverlay.classList.add('d-none');
            submitLoadingOverlay.setAttribute('aria-hidden', 'true');
        }
        
        // 按鈕 click 時立即顯示載入狀態（比 submit 更早觸發，驗證失敗時也能看到）
        // 不 disable 按鈕，避免阻擋 form submit；submit handler 會再 disable
        if (submitBtn) {
            submitBtn.addEventListener('click', function() {
                if (!isSubmitting) {
                    showLoadingState(false);
                }
            }, true); // capture 階段，優先於其他 handler
        }
        
        // 當 HTML5 驗證失敗時，重置按鈕（invalid 不 bubble，需用 capture）
        if (form) {
            form.addEventListener('invalid', function(e) {
                if (form.contains(e.target)) {
                    resetButtonState();
                }
            }, true);
        }
        
        if (form) {
            form.addEventListener('submit', function(e) {
                // 防止重複提交
                if (isSubmitting) {
                    e.preventDefault();
                    return false;
                }
                e.preventDefault(); // 一律先攔截預設送出，通過檢查後再程式化 submit
                
                // 立即顯示載入狀態，讓用戶知道系統正在處理
                isSubmitting = true;
                showLoadingState();
                
                // 延後執行檢查與送出，讓瀏覽器有機會 repaint 載入動畫
                setTimeout(function() {
                    // 檢查是否有至少一張圖片
                    const imageInputs = document.querySelectorAll('.image-input');
                    let hasImage = false;
                    imageInputs.forEach(input => {
                        if (input.files && input.files.length > 0) {
                            hasImage = true;
                        }
                    });

                    if (!hasImage) {
                        resetButtonState();
                        alert('請至少上傳一張商品照片');
                        return;
                    }

                    // 如果價格是 0，顯示提醒
                    const price = parseFloat(priceInput?.value) || 0;
                    if (price === 0) {
                        if (!confirm('您正在刊登免費索取商品，確定要送出嗎？')) {
                            resetButtonState();
                            return;
                        }
                    }

                    // 如果勾選了置頂，顯示確認訊息
                    const useTopPinCheckbox = document.getElementById('UseTopPin');
                    if (useTopPinCheckbox && useTopPinCheckbox.checked) {
                        if (!confirm('確定要使用 1 次置頂機會嗎？此商品將在首頁置頂 7 天。')) {
                            resetButtonState();
                            return;
                        }
                    }

                    // 檢查 jQuery Validation（如果存在）
                    if (typeof $.fn.valid === 'function' && !$(form).valid()) {
                        resetButtonState();
                        return;
                    }
                    
                    // 設定超時保護（30秒後重置按鈕狀態）
                    setTimeout(function() {
                        if (isSubmitting) {
                            resetButtonState();
                        }
                    }, 30000);
                    
                    // 檢查全部通過，程式化送出（不會再次觸發 submit 事件）
                    form.submit();
                }, 50);
            });
        }
    </script>

    <style>
        /* 刊登送出時的載入遮罩 */
        .submit-loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .submit-loading-overlay.submit-loading-overlay.d-none {
            display: none !important;
        }
        .submit-loading-content {
            text-align: center;
        }
        .submit-loading-content .spinner-border {
            border-width: 0.3em;
        }

        /* 手機觸控優化 */
        @@media (max-width: 576px) {
            .image-upload-card .card {
                border-radius: 8px;
                transition: all 0.2s;
            }
            
            .image-upload-card .card:active {
                transform: scale(0.98);
                background-color: #e9ecef !important;
            }
            
            .form-control-lg {
                font-size: 16px; /* 防止 iOS 自動縮放 */
            }
        }

        /* 愛心商品 checkbox 紅色樣式 */
        .charity-checkbox:checked {
            background-color: #dc3545;
            border-color: #dc3545;
        }

        .charity-checkbox:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
        }

        /* 提交按鈕載入狀態與按下過渡 */
        #submitBtn {
            transition: opacity 0.2s ease, transform 0.15s ease;
        }
        #submitBtn:disabled {
            opacity: 0.85;
            cursor: not-allowed;
        }
        #submitBtn:active:not(:disabled) {
            transform: scale(0.98);
        }

        #submitBtnSpinner {
            vertical-align: middle;
        }
    </style>
}


