    "deployEmailResources": { "value": false },
    "sqlAdminLogin": { "value": "__SET_IN_LOCAL_OR_SECRET_STORE__" },
    "sqlAdminPassword": { "value": "__SET_IN_LOCAL_OR_SECRET_STORE__" },
    "lineOidcChannelId": { "value": "__SET_IN_LOCAL_OR_SECRET_STORE__" },
    "lineOidcChannelSecret": { "value": "__SET_IN_LOCAL_OR_SECRET_STORE__" },
    "lineMessagingChannelId": { "value": "__SET_IN_LOCAL_OR_SECRET_STORE__" },
