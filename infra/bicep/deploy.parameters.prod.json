{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "value": "eastasia" },
    "namePrefix": { "value": "neighborgoods" },
    "environmentName": { "value": "prod" },
    "deploySignalR": { "value": true },
    "deployEmailResources": { "value": false },

    "provisionSqlResources": { "value": false },
    "provisionStorageResources": { "value": false },
    "manageExistingSql": { "value": true },
    "manageExistingStorage": { "value": true },

    "existingSqlServerName": { "value": "neighborgoods-prod-sql-ytush2" },
    "existingSqlDatabaseName": { "value": "neighborgoods-prod-db" },
    "existingStorageAccountName": { "value": "neighborgoodsprodytush2b" },
    "existingBlobContainerName": { "value": "neighborgoods-images" },

    "existingSqlConnectionString": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "existingBlobConnectionString": { "value": "__SET_BY_GITHUB_SECRETS__" },

    "sqlAdminLogin": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "sqlAdminPassword": { "value": "__SET_BY_GITHUB_SECRETS__" },

    "databaseSkuName": { "value": "Basic" },
    "databaseTier": { "value": "Basic" },
    "databaseFamily": { "value": "Gen5" },
    "databaseCapacity": { "value": 5 },
    "databaseMaxSizeBytes": { "value": 2147483648 },
    "databaseMinCapacity": { "value": "0.5" },
    "databaseAutoPauseDelay": { "value": 60 },
    "manageExistingStoragePublicAccess": { "value": true },

    "lineOidcChannelId": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "lineOidcChannelSecret": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "lineMessagingChannelId": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "lineMessagingChannelAccessToken": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "lineMessagingChannelSecret": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "lineMessagingBotId": { "value": "__SET_BY_GITHUB_SECRETS__" },
    "jwtSigningKey": { "value": "__SET_BY_GITHUB_SECRETS__" },

    "containerImage": { "value": "ghcr.io/<org>/neighborgoods-api:latest" },
    "containerPort": { "value": 8080 },
    "containerCpu": { "value": "1" },
    "containerMemory": { "value": "2.0Gi" },
    "minReplicas": { "value": 1 },
    "maxReplicas": { "value": 3 },

    "lineMessagingBaseUrl": { "value": "https://api.neighborgoodstw.com" },
    "lineOidcCallbackUrl": { "value": "https://www.neighborgoodstw.com/auth/line/callback" },
    "corsAllowedOrigin0": { "value": "https://www.neighborgoodstw.com" },
    "corsAllowedOrigin1": { "value": "https://neighborgoodstw.com" },
    "repositoryUrl": { "value": "https://github.com/<org>/NGDSH_NeighborGoods" },
    "repositoryBranch": { "value": "main" },
    "appLocation": { "value": "NeighborGoods.Frontend" },
    "outputLocation": { "value": "dist" }
  }
}
