    "lineOidcChannelId": {
      "type": "securestring",
      "metadata": {
        "description": "LINE OIDC ChannelId"
      }
    },
    "lineOidcChannelSecret": {
      "type": "securestring",
      "metadata": {
        "description": "LINE OIDC ChannelSecret"
      }
    },
    "jwtIssuer": {
      "type": "string",
      "defaultValue": "NeighborGoods.Api",
      "metadata": {
        "description": "JWT issuer"
      }
    },
    "jwtAudience": {
      "type": "string",
      "defaultValue": "NeighborGoods.Api.Client",
      "metadata": {
        "description": "JWT audience"
      }
    },
    "jwtSigningKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "JWT signing key (minimum 32 chars)"
      }
    },
    "jwtAccessTokenMinutes": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "JWT access token minutes"
      }
    },
    "jwtRefreshTokenDays": {
      "type": "int",
      "defaultValue": 14,
      "metadata": {
        "description": "JWT refresh token days"
      }
    },
    "lineMessagingChannelId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "LINE Messaging API ChannelId (optional)"
      }
    },
    "lineMessagingAccessToken": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "LINE Messaging API ChannelAccessToken (optional)"
      }
    },
    "lineMessagingChannelSecret": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "LINE Messaging API ChannelSecret (optional)"
      }
    },
    "lineMessagingBotId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "LINE Messaging API BotId (optional), e.g. @559fslxw"
      }
    },
    "lineMessagingBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "LINE Messaging API BaseUrl (optional)"
      }
    },
    "emailConnectionString": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Azure Communication Services Email connection string (optional)"
      }
    },
    "emailFromAddress": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Email sender address (optional)"
      }
    },
    "emailFromDisplayName": {
      "type": "string",
      "defaultValue": "NeighborGoods",
      "metadata": {
        "description": "Email sender display name (optional)"
      }
    },
    "emailLogoUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Email logo URL (optional)"
      }
    },
    "emailBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Email base URL (optional)"
      }
    },
    "lineOidcCallbackUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "LINE OIDC callback full URL"
      }
    },
    "lineOidcScope": {
      "type": "string",
      "defaultValue": "openid profile",
      "metadata": {
        "description": "LINE OIDC scope"
      }
    },
    "aspnetcoreEnvironment": {
      "type": "string",
      "defaultValue": "Production",
      "metadata": {
        "description": "App environment"
      }
