    "corsAllowedOrigin0": {
      "type": "string",
      "defaultValue": "http://localhost:5173",
      "metadata": {
        "description": "Allowed CORS origin #0"
      }
    },
    "corsAllowedOrigin1": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Allowed CORS origin #1"
      }
    }
  },
  "variables": {
    "suffix": "[toLower(uniqueString(resourceGroup().id, parameters('namePrefix'), parameters('environmentName')))]",
    "webAppName": "[format('{0}-{1}-web-{2}', parameters('namePrefix'), parameters('environmentName'), take(variables('suffix'), 6))]",
    "appServicePlanName": "[format('{0}-{1}-plan', parameters('namePrefix'), parameters('environmentName'))]",
    "storageAccountName": "[toLower(take(replace(format('{0}{1}{2}', parameters('namePrefix'), parameters('environmentName'), variables('suffix')), '-', ''), 24))]",
    "blobContainerName": "neighborgoods-images",
    "sqlServerName": "[format('{0}-{1}-sql-{2}', parameters('namePrefix'), parameters('environmentName'), take(variables('suffix'), 6))]",
    "sqlDatabaseName": "[format('{0}-{1}-db', parameters('namePrefix'), parameters('environmentName'))]",
    "signalRName": "[format('{0}-{1}-signalr-{2}', parameters('namePrefix'), parameters('environmentName'), take(variables('suffix'), 6))]"
  },
  "resources": {
    "storageAccount": {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": true,
        "supportsHttpsTrafficOnly": true
      }
    },
    "blobService": {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageAccountName'), 'default')]",
      "dependsOn": [
        "storageAccount"
      ]
    },
    "blobContainer": {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageAccountName'), 'default', variables('blobContainerName'))]",
      "properties": {
        "publicAccess": "Blob"
      },
      "dependsOn": [
        "blobService"
      ]
    },
    "sqlServer": {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-08-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "version": "12.0",
        "publicNetworkAccess": "Enabled"
      }
    },
    "sqlDatabase": {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sqlDatabaseSkuName')]",
        "tier": "[parameters('sqlDatabaseSkuTier')]",
        "family": "[parameters('sqlDatabaseSkuFamily')]",
        "capacity": "[parameters('sqlDatabaseSkuCapacity')]"
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": "[parameters('sqlDatabaseMaxSizeBytes')]",
        "minCapacity": "[json(parameters('sqlDatabaseMinCapacity'))]",
        "autoPauseDelay": "[parameters('sqlDatabaseAutoPauseDelay')]"
      },
      "dependsOn": [
        "sqlServer"
      ]
    },
    "sqlFirewallAllowAzure": {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-08-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "sqlServer"
      ]
    },
    "appServicePlan": {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('appServicePlanSkuName')]",
        "tier": "[parameters('appServicePlanSkuTier')]"
      },
      "kind": "app",
      "properties": {
        "reserved": false
      }
    },
    "signalR": {
      "condition": "[parameters('deploySignalR')]",
      "type": "Microsoft.SignalRService/signalR",
      "apiVersion": "2024-03-01-preview",
      "name": "[variables('signalRName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Free_F1",
        "tier": "Free",
        "capacity": 1
      },
      "kind": "SignalR",
      "properties": {
        "publicNetworkAccess": "Enabled"
      }
    },
    "webApp": {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "minTlsVersion": "1.2",
          "alwaysOn": false,
          "ftpsState": "Disabled",
          "appSettings": "[concat(createArray(createObject('name', 'ASPNETCORE_ENVIRONMENT', 'value', parameters('aspnetcoreEnvironment')), createObject('name', 'ConnectionStrings__DefaultConnection', 'value', format('Server=tcp:{0}.database.windows.net,1433;Initial Catalog={1};Persist Security Info=False;User ID={2};Password={3};MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;', variables('sqlServerName'), variables('sqlDatabaseName'), parameters('sqlAdminLogin'), parameters('sqlAdminPassword'))), createObject('name', 'AzureBlob__ConnectionString', 'value', format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('storageAccountName'), listKeys('storageAccount', '2023-05-01').keys[0].value, environment().suffixes.storage)), createObject('name', 'AzureBlob__ContainerName', 'value', variables('blobContainerName')), createObject('name', 'Line__ChannelId', 'value', parameters('lineOidcChannelId')), createObject('name', 'Line__ChannelSecret', 'value', parameters('lineOidcChannelSecret')), createObject('name', 'Line__CallbackUrl', 'value', parameters('lineOidcCallbackUrl')), createObject('name', 'Line__Scope', 'value', parameters('lineOidcScope')), createObject('name', 'Jwt__Issuer', 'value', parameters('jwtIssuer')), createObject('name', 'Jwt__Audience', 'value', parameters('jwtAudience')), createObject('name', 'Jwt__SigningKey', 'value', parameters('jwtSigningKey')), createObject('name', 'Jwt__AccessTokenMinutes', 'value', string(parameters('jwtAccessTokenMinutes'))), createObject('name', 'Jwt__RefreshTokenDays', 'value', string(parameters('jwtRefreshTokenDays'))), createObject('name', 'Cors__AllowedOrigins__0', 'value', parameters('corsAllowedOrigin0')), createObject('name', 'Cors__AllowedOrigins__1', 'value', parameters('corsAllowedOrigin1')), createObject('name', 'LineMessagingApi__ChannelId', 'value', parameters('lineMessagingChannelId')), createObject('name', 'LineMessagingApi__ChannelAccessToken', 'value', parameters('lineMessagingAccessToken')), createObject('name', 'LineMessagingApi__ChannelSecret', 'value', parameters('lineMessagingChannelSecret')), createObject('name', 'LineMessagingApi__BotId', 'value', parameters('lineMessagingBotId')), createObject('name', 'LineMessagingApi__BaseUrl', 'value', parameters('lineMessagingBaseUrl')), createObject('name', 'EmailNotification__ConnectionString', 'value', parameters('emailConnectionString')), createObject('name', 'EmailNotification__FromEmailAddress', 'value', parameters('emailFromAddress')), createObject('name', 'EmailNotification__FromDisplayName', 'value', parameters('emailFromDisplayName')), createObject('name', 'EmailNotification__LogoUrl', 'value', parameters('emailLogoUrl')), createObject('name', 'EmailNotification__BaseUrl', 'value', parameters('emailBaseUrl'))), if(parameters('deploySignalR'), createArray(createObject('name', 'Azure__SignalR__ConnectionString', 'value', listKeys('signalR', '2024-03-01-preview').primaryConnectionString)), createArray()))]"
        }
      },
      "dependsOn": [
        "appServicePlan",
        "blobContainer",
        "signalR",
        "sqlDatabase",
        "sqlServer",
        "storageAccount"
      ]
    }
  },
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference('webApp').defaultHostName)]"
    },
    "appServicePlanName": {
      "type": "string",
      "value": "[variables('appServicePlanName')]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "sqlServerName": {
      "type": "string",
      "value": "[variables('sqlServerName')]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "value": "[variables('sqlDatabaseName')]"
    },
    "signalRName": {
      "type": "string",
      "value": "[if(parameters('deploySignalR'), variables('signalRName'), 'not-deployed')]"
    },
    "signalRHostName": {
      "type": "string",
      "value": "[if(parameters('deploySignalR'), reference('signalR').hostName, '')]"
    },
    "signalRPrimaryConnectionString": {
      "type": "securestring",
      "value": "[if(parameters('deploySignalR'), listKeys('signalR', '2024-03-01-preview').primaryConnectionString, '')]"
    }
  }
}